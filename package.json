{
	"name": "vite-plugin-iife",
	"version": "2.1.1",
	"description": "Vite plugin for simple IIFE-compiled script imports.",
	"keywords": [
		"vite-plugin",
		"iife",
		"vite",
		"import",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/vite-plugin-iife",
	"bugs": "https://github.com/kitschpatrol/vite-plugin-iife/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/vite-plugin-iife.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./ext": {
			"types": "./ext.d.ts"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"./ext.d.ts",
		"dist"
	],
	"scripts": {
		"build": "tsx ./scripts/build-plugin.ts && tsc -p tsconfig.plugin.json",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"pretty-bytes": "^7.1.0"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.6.2",
		"@types/node": "^20.19.41",
		"@vitest/browser-playwright": "^4.1.6",
		"bumpp": "^11.1.0",
		"esbuild": "^0.28.0",
		"playwright": "^1.60.0",
		"shx": "^0.4.0",
		"tsx": "^4.22.3",
		"typescript": "^5.9.3",
		"vite": "^7.3.3",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
	},
	"packageManager": "pnpm@11.3.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.22.2"
		}
	}
}
